{
  "id": "home",
  "label": "Home",
  "repeatable": false,
  "status": true,
  "format": "custom",
  "json": {
    "Main": {
      "projects": {
        "type": "Group",
        "config": {
          "label": "Projects",
          "fields": {
            "title": {
              "type": "Text",
              "config": {
                "label": "Title",
                "placeholder": "FileCoin Station"
              }
            },
            "description": {
              "type": "Text",
              "config": {
                "label": "Description",
                "placeholder": "Short project description"
              }
            },
            "image": {
              "type": "Image",
              "config": {
                "label": "Image",
                "constraint": {},
                "thumbnails": []
              }
            },
            "url": {
              "type": "Link",
              "config": {
                "label": "URL",
                "select": null,
                "allowTargetBlank": false
              }
            },
            "com": {
              "type": "Boolean",
              "config": {
                "label": "Coming Soon",
                "placeholder_false": "false",
                "placeholder_true": "true",
                "default_value": false
              }
            }
          }
        }
      },
      "faqs": {
        "type": "Group",
        "config": {
          "label": "FAQs",
          "fields": {
            "number": {
              "type": "Text",
              "config": {
                "label": "Number",
                "placeholder": "01"
              }
            },
            "question": {
              "type": "Text",
              "config": {
                "label": "Question",
                "placeholder": "What is Subvisual?"
              }
            },
            "answer": {
              "type": "Text",
              "config": {
                "label": "Answer",
                "placeholder": "A product and venture studio."
              }
            },
            "is_link": {
              "type": "Boolean",
              "config": {
                "label": "Is Link",
                "default_value": false,
                "placeholder_true": "Yes",
                "placeholder_false": "No"
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "Link",
                "placeholder": "",
                "select": null,
                "allowTargetBlank": true,
                "allowText": true,
                "repeat": false
              }
            }
          }
        }
      }
    }
  }
}
