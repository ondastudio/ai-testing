{
  "id": "blog_post",
  "label": "Blog Post",
  "repeatable": true,
  "status": true,
  "format": "custom",
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": "my-blog-post"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Blog post title"
        }
      },
      "excerpt": {
        "type": "Text",
        "config": {
          "label": "Excerpt",
          "placeholder": "A short description shown on the listing page"
        }
      },
      "cover_image": {
        "type": "Image",
        "config": {
          "label": "Cover Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "date": {
        "type": "Date",
        "config": {
          "label": "Date",
          "placeholder": "2024-01-01"
        }
      },
      "author": {
        "type": "Text",
        "config": {
          "label": "Author",
          "placeholder": "Subvisual"
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "allowTargetBlank": true,
          "multi": "paragraph,preformatted,heading2,heading3,strong,em,hyperlink,image,list-item,o-list-item"
        }
      }
    }
  }
}
